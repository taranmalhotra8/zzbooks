# LLM Provider (set ONE of these, or use LLM_BASE_URL for OpenAI-compatible APIs)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# For OpenAI-compatible APIs (DeepSeek, Kimi, Minimax, Together, Groq, etc.)
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_BASE_URL=https://api.minimax.chat/v1

# Default LLM settings (override per-book in topic.yml pipeline section)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Search Providers (set one or more — all configured providers are used)
TAVILY_API_KEY=tvly-...
# SERPAPI_API_KEY=...
# BRAVE_SEARCH_API_KEY=...

# Image Generation
# BANANA_API_KEY=...

# Pipeline mode: "full" (uses APIs) or "mock" (no API calls, for testing)
PIPELINE_MODE=full
